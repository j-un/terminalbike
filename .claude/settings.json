{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "gofmt -l . | grep . && exit 1; go test ./...",
            "timeout": 60,
            "statusMessage": "Running format check and tests..."
          }
        ]
      }
    ]
  }
}
